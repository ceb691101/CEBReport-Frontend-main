## Frontend API base URL
# Leave empty to use relative URLs (recommended in dev with Vite proxy).
# Set this when the API is hosted on a different origin/port.
#
# Examples:
# VITE_API_BASE=
# VITE_CBRS_API_BASE=http://10.128.1.126
# VITE_SMART_API_BASE=http://smartceb.ceb:81
# VITE_MIS_API_BASE=http://10.128.1.126
# Optional: exact endpoint override for AD login when deployed routing differs.
# Example: VITE_AD_LOGIN_API_URL=http://smartceb.ceb:81/SMART_API/api/UserManagement/ValidateADLoginCEBINFO
VITE_API_BASE=
VITE_CBRS_API_BASE=
VITE_SMART_API_BASE=
VITE_MIS_API_BASE=
VITE_AD_LOGIN_API_URL=
# VITE_API_BASE=http://localhost:44381
# VITE_API_BASE=http://10.128.1.126
VITE_API_BASE=

