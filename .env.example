## Frontend API base URL
# Leave empty to use relative URLs (recommended in dev with Vite proxy).
# Set this when the API is hosted on a different origin/port.
#
# Examples:
# VITE_API_BASE=
# VITE_CBRS_API_BASE=http://your-cbrs-api-ip
# VITE_SMART_API_BASE=http://your-smart-api-domain
# VITE_MIS_API_BASE=http://your-mis-api-ip
# Optional: exact endpoint override for AD login when deployed routing differs.
# Example: VITE_AD_LOGIN_API_URL=http://your-ad-login-url/SMART_API/api/UserManagement/ValidateADLoginCEBINFO
VITE_API_BASE=
VITE_CBRS_API_BASE=
VITE_SMART_API_BASE=
VITE_MIS_API_BASE=
VITE_AD_LOGIN_API_URL=

# Vite proxy API Targets
# Copy these to your local .env file and fill in your real server details.
VITE_LOCAL_API=http://localhost:44381
VITE_SERVER_API=http://your-internal-api-server-ip
VITE_SMART_API=http://your-smart-api-domain-or-ip
VITE_MRMS_API=http://your-mrms-api-domain-or-ip
